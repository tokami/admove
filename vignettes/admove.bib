@article{andersen_using_2007,
  title = {Using the Particle Filter to Geolocate {{Atlantic}} Cod ( {{{\emph{Gadus}}}}{\emph{ Morhua}} ) in the {{Baltic Sea}}, with Special Emphasis on Determining Uncertainty},
  author = {Andersen, K H and Nielsen, A and Thygesen, U H and Hinrichsen, H -H and Neuenfeldt, S},
  year = 2007,
  month = apr,
  journal = {Canadian Journal of Fisheries and Aquatic Sciences},
  volume = {64},
  number = {4},
  pages = {618--627},
  issn = {0706-652X, 1205-7533},
  doi = {10.1139/f07-037},
  urldate = {2026-01-21},
  abstract = {The use of archival tags on fish gives information of individual behaviour with an unprecedented high resolution in time. A central problem in the analysis of data from retrieved tags is the geolocation, namely the infererence of movements of the fish by comparing the data from the tags with environmental observations like temperature, tide, day length, etc. The result is usually represented as a track; however, the spatial and temporal variability in the precision is often substantial. In this article, the particle filter is applied to geolocate Atlantic cod (Gadus morhua) in the Baltic Sea, leading to a representation of the results as probability distributions for each time step, thus giving an explicit representation of uncertainty. Furthermore, the method is used to estimate the magnitude of the error in the measurements by the tags and the swimming velocity of the fish. The average swimming velocity during a day was estimated to be around 0.20 m{$\cdot$}s--1 for fish of \textasciitilde 60 cm length. The method is general and the presentation is formulated to facilitate implementation for different systems where other quantities are observed.},
  copyright = {http://www.nrcresearchpress.com/page/about/CorporateTextAndDataMining},
  langid = {english},
  file = {/home/tobm/Zotero/storage/ARLMMVC7/Andersen et al. - 2007 - Using the particle filter to geolocate Atlantic cod ( Gadus morhua ) in the Baltic Sea, with.pdf}
}

