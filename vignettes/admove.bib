  shorttitle = {Signalling in Groups},
  author = {Demartsev, Vlad and Gersick, Andrew S. and Jensen, Frants H. and Thomas, Mara and Roch, Marie A. and Manser, Marta B. and Strandburg-Peshkin, Ariana},
