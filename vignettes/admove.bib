@article{thompson_detecting_2022,
  title = {Detecting Seasonal Episodic-like Spatio-temporal Memory Patterns Using Animal Movement Modelling},
  author = {Thompson, Peter R. and Derocher, Andrew E. and Edwards, Mark A. and Lewis, Mark A.},
